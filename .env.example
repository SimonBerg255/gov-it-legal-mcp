# Copy this file to .env and fill in your values
# On Railway, set these as environment variables in the dashboard

# JWT secret key — set this to any long random string you generate
# Generate one with: python3 -c "import secrets; print(secrets.token_hex(32))"
MCP_SERVER_JWT_SECRET=your-secret-key-here

# JWT issuer — set to your Intric workspace URL or any identifier string
MCP_SERVER_JWT_ISSUER=https://your-intric-instance.com

# JWT audience — set to match what your Intric instance sends
MCP_SERVER_JWT_AUDIENCE=italian-legal-mcp
